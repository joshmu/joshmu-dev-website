{
  "name": "joshmu-dev-website",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "dev",
    "josh mu",
    "portfolio",
    "webdev",
    "website"
  ],
  "homepage": "https://github.com/joshmu/joshmu-dev-website",
  "bugs": {
    "url": "https://github.com/joshmu/joshmu-dev-website/issues"
  },
  "license": "MIT",
  "author": "Josh Mu",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshmu/joshmu-dev-website.git"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "shellcheck": "git ls-files '*.sh' | xargs shellcheck",
    "bash32-compat": "bash scripts/check-bash32-compat.sh",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#.next'",
    "lint:knip": "pnpm exec knip",
    "audit": "pnpm audit --audit-level=high",
    "prepare": "husky",
    "plop": "plop"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "framer-motion": "^6.2.1",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-device-detect": "^2.1.2",
    "react-dom": "^19.2.4",
    "react-ga": "^3.3.0",
    "react-icons": "^4.3.1",
    "react-intersection-observer": "^8.33.1",
    "react-player": "^2.9.0",
    "react-scroll": "^1.8.4",
    "three": "^0.136.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-scroll": "^1.8.3",
    "@types/three": "^0.136.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "plop": "^3.0.5",
    "postcss": "^8.4.5",
    "postcss-preset-env": "^7.2.3",
    "sass": "^1.98.0",
    "tailwindcss": "^3.0.15",
    "tailwindcss-debug-screens": "^2.2.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
