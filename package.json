{
  "name": "joshmu-dev-website",
  "version": "0.1.0",
  "keywords": [
    "dev",
    "josh mu",
    "portfolio",
    "webdev",
    "website"
  ],
  "homepage": "https://github.com/joshmu/joshmu-dev-website",
  "bugs": {
    "url": "https://github.com/joshmu/joshmu-dev-website/issues"
  },
  "license": "MIT",
  "author": "Josh Mu",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshmu/joshmu-dev-website.git"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "shellcheck": "git ls-files '*.sh' | xargs shellcheck",
    "bash32-compat": "bash scripts/check-bash32-compat.sh",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#.next'",
    "lint:knip": "pnpm exec knip",
    "audit": "pnpm audit --audit-level=critical",
    "prepare": "husky",
    "plop": "plop"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "framer-motion": "^12.42.2",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-device-detect": "^2.1.2",
    "react-dom": "^19.2.7",
    "react-ga": "^3.3.0",
    "react-icons": "^5.7.0",
    "react-intersection-observer": "^10.0.3",
    "react-player": "^3.4.0",
    "react-scroll": "^1.8.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-scroll": "^1.8.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.72.0",
    "plop": "^4.0.5",
    "postcss": "^8.5.19",
    "postcss-preset-env": "^11.3.0",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-debug-screens": "^3.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9"
    }
  }
}
